<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>FocusQuest — Concentration Trainer</title>
<style>
  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html, body {
    margin: 0; padding: 0;
    height: 100%;
    overscroll-behavior: none;
    -webkit-user-select: none; user-select: none;
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", system-ui, sans-serif;
  }
  body {
    background: radial-gradient(ellipse at top, #1e1b4b 0%, #0f172a 50%, #020617 100%);
    color: #f8fafc;
    min-height: 100vh;
    padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    overflow-x: hidden;
  }
  #app { max-width: 640px; margin: 0 auto; padding: 16px 16px 96px; position: relative; }

/* ===== Typography ===== */
h1 {
font-size: 32px; font-weight: 800; letter-spacing: -0.02em;
margin: 8px 0 4px; background: linear-gradient(135deg, #a5b4fc, #f0abfc, #fbbf24);
-webkit-background-clip: text; background-clip: text; color: transparent;
}
h2 { font-size: 22px; font-weight: 700; margin: 20px 0 12px; letter-spacing: -0.01em; }
h3 { font-size: 16px; font-weight: 600; margin: 14px 0 8px; color: #cbd5e1; }
.sub { font-size: 13px; color: #94a3b8; margin: 0 0 16px; }

/* ===== Cards ===== */
.card {
background: rgba(30, 41, 59, 0.5);
backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
border: 1px solid rgba(148, 163, 184, 0.15);
border-radius: 20px; padding: 16px; margin-bottom: 14px;
box-shadow: 0 8px 32px rgba(0,0,0,0.25);
}

/* ===== Buttons ===== */
.btn {
display: inline-flex; align-items: center; justify-content: center; gap: 8px;
padding: 14px 20px; border-radius: 14px; border: none;
font-size: 16px; font-weight: 600; cursor: pointer;
background: linear-gradient(135deg, #6366f1, #8b5cf6);
color: white; width: 100%; min-height: 52px;
transition: transform 0.15s, box-shadow 0.15s;
box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
}
.btn:active { transform: scale(0.97); }
.btn.secondary { background: rgba(71, 85, 105, 0.6); box-shadow: none; }
.btn.danger { background: linear-gradient(135deg, #ef4444, #dc2626); box-shadow: 0 4px 16px rgba(239, 68, 68, 0.3); }
.btn.success { background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 4px 16px rgba(16, 185, 129, 0.3); }
.btn.small { padding: 8px 14px; font-size: 14px; min-height: 38px; width: auto; }
.btn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.btn-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }

/* ===== Inputs ===== */
input[type=“text”], input[type=“number”] {
width: 100%; padding: 14px 16px; border-radius: 12px;
border: 1px solid rgba(148, 163, 184, 0.25);
background: rgba(15, 23, 42, 0.6); color: #f8fafc;
font-size: 16px; -webkit-user-select: auto; user-select: auto;
outline: none;
}
input:focus { border-color: #818cf8; box-shadow: 0 0 0 3px rgba(129, 140, 248, 0.15); }

/* ===== Profile list ===== */
.profile-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
.profile-card {
background: rgba(51, 65, 85, 0.4); border: 1px solid rgba(148, 163, 184, 0.15);
border-radius: 16px; padding: 14px; text-align: center; cursor: pointer;
position: relative; transition: all 0.2s;
}
.profile-card:active { transform: scale(0.97); }
.profile-card.selected { border-color: #818cf8; background: rgba(99, 102, 241, 0.15); }
.avatar {
width: 56px; height: 56px; border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-size: 28px; margin: 0 auto 8px;
background: linear-gradient(135deg, var(–ring-a, #6366f1), var(–ring-b, #8b5cf6));
}
.profile-name { font-weight: 600; font-size: 14px; margin-bottom: 4px; }
.profile-stats { font-size: 11px; color: #94a3b8; }
.delete-btn {
position: absolute; top: 6px; right: 6px;
width: 24px; height: 24px; border-radius: 50%; border: none;
background: rgba(239, 68, 68, 0.85); color: white; font-size: 14px;
cursor: pointer; display: flex; align-items: center; justify-content: center;
line-height: 1; padding: 0;
}

/* ===== Avatar picker ===== */
.avatar-picker { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0; }
.avatar-option {
width: 44px; height: 44px; border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-size: 22px; cursor: pointer; background: rgba(51, 65, 85, 0.5);
border: 2px solid transparent;
}
.avatar-option.selected { border-color: #a5b4fc; background: rgba(99, 102, 241, 0.25); }

/* ===== Mode / difficulty picker ===== */
.mode-card {
background: rgba(51, 65, 85, 0.4); border: 1px solid rgba(148, 163, 184, 0.15);
border-radius: 16px; padding: 16px; margin-bottom: 10px;
cursor: pointer; display: flex; align-items: center; gap: 14px;
transition: all 0.2s;
}
.mode-card:active { transform: scale(0.98); }
.mode-card.active { border-color: #818cf8; background: rgba(99, 102, 241, 0.15); }
.mode-icon { font-size: 32px; }
.mode-info { flex: 1; }
.mode-title { font-weight: 700; font-size: 15px; margin-bottom: 2px; }
.mode-desc { font-size: 12px; color: #94a3b8; }

.diff-row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin: 8px 0; }
.diff-chip {
padding: 10px 4px; border-radius: 10px; text-align: center;
background: rgba(51, 65, 85, 0.5); cursor: pointer; font-size: 11px;
border: 2px solid transparent; font-weight: 600;
}
.diff-chip.active { border-color: #fbbf24; background: rgba(251, 191, 36, 0.15); }
.diff-chip .num { display: block; font-size: 18px; font-weight: 800; color: #fbbf24; }

/* ===== Schulte grid ===== */
.schulte-stats {
display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;
padding: 12px; background: rgba(15, 23, 42, 0.5); border-radius: 14px;
margin-bottom: 14px;
}
.stat { text-align: center; }
.stat-label { font-size: 10px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; }
.stat-value { font-size: 20px; font-weight: 800; margin-top: 2px; }
.stat-value.target { color: #fbbf24; }
.stat-value.time { color: #a5b4fc; }

.schulte-grid {
display: grid; gap: 4px; margin: 0 auto;
background: rgba(15, 23, 42, 0.4); padding: 6px; border-radius: 14px;
aspect-ratio: 1; max-width: 560px; width: 100%;
}
.schulte-cell {
display: flex; align-items: center; justify-content: center;
background: linear-gradient(135deg, rgba(71, 85, 105, 0.6), rgba(51, 65, 85, 0.8));
border-radius: 8px; cursor: pointer; color: #f8fafc;
font-weight: 700; border: 1px solid rgba(148, 163, 184, 0.1);
transition: all 0.1s;
}
.schulte-cell:active { transform: scale(0.94); }
.schulte-cell.correct {
background: linear-gradient(135deg, #10b981, #059669);
animation: pop 0.3s ease;
}
.schulte-cell.wrong {
background: linear-gradient(135deg, #ef4444, #dc2626);
animation: shake 0.3s ease;
}
@keyframes pop { 0%{transform:scale(1);} 50%{transform:scale(1.15);} 100%{transform:scale(1);} }
@keyframes shake { 0%,100%{transform:translateX(0);} 25%{transform:translateX(-4px);} 75%{transform:translateX(4px);} }

/* ===== Memory game ===== */
.memory-display {
min-height: 120px; border-radius: 16px;
background: rgba(15, 23, 42, 0.6); display: flex;
align-items: center; justify-content: center;
font-size: 72px; font-weight: 800; letter-spacing: 0.05em;
margin-bottom: 14px; border: 1px solid rgba(148, 163, 184, 0.15);
}
.memory-display.sequence { color: #fbbf24; }
.memory-display.input { color: #a5b4fc; font-size: 48px; }
.memory-display .hint { font-size: 16px; color: #94a3b8; letter-spacing: normal; font-weight: 500; text-align: center; padding: 0 16px; }

.keypad { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 10px; }
.key {
padding: 18px 0; border-radius: 14px; border: none;
background: linear-gradient(135deg, rgba(71, 85, 105, 0.8), rgba(51, 65, 85, 0.9));
color: white; font-size: 24px; font-weight: 700; cursor: pointer;
box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}
.key:active { transform: scale(0.95); background: rgba(99, 102, 241, 0.6); }
.key.action { background: linear-gradient(135deg, #475569, #334155); font-size: 16px; }
.key.submit { background: linear-gradient(135deg, #10b981, #059669); }

/* ===== Timer bar ===== */
.timer-bar {
height: 6px; background: rgba(71, 85, 105, 0.4); border-radius: 3px;
overflow: hidden; margin: 10px 0;
}
.timer-fill {
height: 100%; background: linear-gradient(90deg, #10b981, #fbbf24, #ef4444);
transition: width 0.1s linear; width: 100%;
}

/* ===== Screens & header ===== */
.screen { display: none; }
.screen.active { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

.header {
display: flex; align-items: center; justify-content: space-between;
padding: 4px 0 12px; gap: 10px;
}
.back-btn {
background: rgba(51, 65, 85, 0.6); border: none; color: white;
width: 40px; height: 40px; border-radius: 12px; font-size: 20px; cursor: pointer;
display: flex; align-items: center; justify-content: center;
}
.current-user {
display: flex; align-items: center; gap: 8px;
padding: 6px 12px 6px 6px; background: rgba(51, 65, 85, 0.5);
border-radius: 999px; font-size: 13px; font-weight: 600;
}
.current-user .avatar { width: 28px; height: 28px; font-size: 14px; margin: 0; }

/* ===== Leaderboard ===== */
.lb-entry {
display: flex; align-items: center; gap: 12px;
padding: 10px 12px; border-radius: 12px;
background: rgba(51, 65, 85, 0.4); margin-bottom: 6px;
}
.lb-rank {
width: 32px; height: 32px; border-radius: 50%;
display: flex; align-items: center; justify-content: center;
background: rgba(71, 85, 105, 0.6); font-weight: 700; font-size: 13px;
}
.lb-rank.gold { background: linear-gradient(135deg, #fbbf24, #f59e0b); }
.lb-rank.silver { background: linear-gradient(135deg, #cbd5e1, #94a3b8); }
.lb-rank.bronze { background: linear-gradient(135deg, #fb923c, #ea580c); }
.lb-name { flex: 1; font-weight: 600; font-size: 14px; }
.lb-score { font-weight: 700; color: #fbbf24; }

/* ===== Segmented tabs ===== */
.tabs { display: flex; gap: 4px; padding: 4px; background: rgba(15, 23, 42, 0.5); border-radius: 12px; margin-bottom: 12px; }
.tab { flex: 1; padding: 10px; text-align: center; border-radius: 9px; cursor: pointer; font-size: 13px; font-weight: 600; color: #94a3b8; }
.tab.active { background: rgba(99, 102, 241, 0.4); color: white; }

/* ===== Result overlay ===== */
.overlay {
position: fixed; inset: 0; background: rgba(2, 6, 23, 0.85);
backdrop-filter: blur(8px); z-index: 100;
display: none; align-items: center; justify-content: center; padding: 20px;
}
.overlay.active { display: flex; animation: fadeIn 0.3s ease; }
.overlay-card {
background: linear-gradient(135deg, rgba(30, 41, 59, 0.95), rgba(15, 23, 42, 0.95));
border: 1px solid rgba(148, 163, 184, 0.2);
border-radius: 24px; padding: 28px 24px; max-width: 420px; width: 100%;
text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.overlay-emoji { font-size: 56px; margin-bottom: 8px; }
.overlay-title { font-size: 24px; font-weight: 800; margin-bottom: 8px; }
.overlay-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 16px 0; }
.overlay-stat { padding: 12px; background: rgba(15, 23, 42, 0.5); border-radius: 12px; }

.empty { text-align: center; color: #64748b; padding: 28px 16px; font-size: 14px; }

/* Small screens tighten up */
@media (max-width: 380px) {
h1 { font-size: 26px; }
.memory-display { font-size: 56px; }
.memory-display.input { font-size: 40px; }
.key { font-size: 20px; padding: 16px 0; }
}
</style>

</head>
