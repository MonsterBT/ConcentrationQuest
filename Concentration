<script>
/* ==================== STATE & STORAGE ==================== */
const STORAGE_KEY = 'focusquest_v1';
const AVATARS = ['🦊','🐼','🐵','🦁','🐯','🐸','🐙','🦄','🐲','🦉','🐢','🐨','🦖','🐳','🦋','🐝'];
const RING_COLORS = [
  ['#6366f1','#8b5cf6'],['#ec4899','#f43f5e'],['#10b981','#06b6d4'],
  ['#f59e0b','#ef4444'],['#14b8a6','#6366f1'],['#a855f7','#ec4899']
];

let state = loadState();
function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) return JSON.parse(raw);
  } catch(e) {}
  return { profiles: [], currentProfileId: null };
}
function saveState() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
}

function currentProfile() {
  return state.profiles.find(p => p.id === state.currentProfileId);
}
function newProfile(name, avatar) {
  return {
    id: 'p_' + Date.now() + '_' + Math.random().toString(36).slice(2,7),
    name, avatar,
    ringIdx: Math.floor(Math.random() * RING_COLORS.length),
    schulte: {
      // per-difficulty: bestTime (classic), bestTimedCount (sprint)
      stats: { 1:{bt:null,btc:0,plays:0}, 2:{bt:null,btc:0,plays:0}, 3:{bt:null,btc:0,plays:0}, 4:{bt:null,btc:0,plays:0}, 5:{bt:null,btc:0,plays:0} }
    },
    memory: {
      bestLength: 0, bestScore: 0,
      stats: { 1:{bl:0,plays:0}, 2:{bl:0,plays:0}, 3:{bl:0,plays:0}, 4:{bl:0,plays:0}, 5:{bl:0,plays:0} }
    }
  };
}

/* ==================== SCREEN NAV ==================== */
function goto(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  if (name === 'home') renderHome();
  if (name === 'schulte-setup') renderSchulteSetup();
  if (name === 'memory-setup') renderMemorySetup();
  window.scrollTo(0,0);
}

/* ==================== HOME / PROFILES ==================== */
function renderHome() {
  const list = document.getElementById('profile-list');
  list.innerHTML = '';
  if (state.profiles.length === 0) {
    list.innerHTML = '<div class="empty" style="grid-column:1/-1;">No profiles yet.<br>Create one to begin.</div>';
    document.getElementById('home-main').style.display = 'none';
    return;
  }
  state.profiles.forEach(p => {
    const ring = RING_COLORS[p.ringIdx % RING_COLORS.length];
    const isSel = p.id === state.currentProfileId;
    const bestL = p.memory.bestLength || 0;
    const card = document.createElement('div');
    card.className = 'profile-card' + (isSel ? ' selected' : '');
    card.innerHTML = `
      <button class="delete-btn" onclick="event.stopPropagation(); deleteProfile('${p.id}')">×</button>
      <div class="avatar" style="--ring-a:${ring[0]};--ring-b:${ring[1]}">${p.avatar}</div>
      <div class="profile-name">${escapeHtml(p.name)}</div>
      <div class="profile-stats">Best memory: ${bestL}</div>
    `;
    card.onclick = () => { state.currentProfileId = p.id; saveState(); renderHome(); };
    list.appendChild(card);
  });
  if (!currentProfile() && state.profiles.length > 0) {
    state.currentProfileId = state.profiles[0].id; saveState();
  }
  document.getElementById('home-main').style.display = currentProfile() ? 'block' : 'none';
  renderProgress('schulte');
  renderLeaderboard('schulte');
}

function deleteProfile(id) {
  if (!confirm('Delete this profile? All progress will be lost.')) return;
  state.profiles = state.profiles.filter(p => p.id !== id);
  if (state.currentProfileId === id) state.currentProfileId = state.profiles[0]?.id || null;
  saveState(); renderHome();
}

let draftAvatar = AVATARS[0];
function showAddProfile() {
  draftAvatar = AVATARS[Math.floor(Math.random() * AVATARS.length)];
  document.getElementById('new-name').value = '';
  const picker = document.getElementById('avatar-picker');
  picker.innerHTML = '';
  AVATARS.forEach(a => {
    const el = document.createElement('div');
    el.className = 'avatar-option' + (a === draftAvatar ? ' selected' : '');
    el.textContent = a;
    el.onclick = () => {
      draftAvatar = a;
      picker.querySelectorAll('.avatar-option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
    };
    picker.appendChild(el);
  });
  goto('add-profile');
}

function saveProfile() {
  const name = document.getElementById('new-name').value.trim();
  if (!name) { alert('Please enter a name.'); return; }
  const p = newProfile(name, draftAvatar);
  state.profiles.push(p);
  state.currentProfileId = p.id;
  saveState();
  goto('home');
}

