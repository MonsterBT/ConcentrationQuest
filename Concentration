          <div style="font-size:13px;margin-top:4px;">Best time: <b style="color:#a5b4fc;">${bt}</b></div>
          <div style="font-size:13px;">Sprint best: <b style="color:#fbbf24;">${btc}</b> grids</div>
        </div>`;
    }
    html += '</div>';
    c.innerHTML = html;
  } else {
    let html = `<div style="padding:12px;background:rgba(15,23,42,0.5);border-radius:10px;margin-bottom:8px;">
      <div style="font-size:12px;color:#94a3b8;">Overall best</div>
      <div style="display:flex;justify-content:space-between;margin-top:4px;">
        <div>Longest sequence: <b style="color:#fbbf24;">${p.memory.bestLength}</b> digits</div>
        <div>Top score: <b style="color:#a5b4fc;">${p.memory.bestScore}</b></div>
      </div>
    </div>`;
    html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">';
    for (let d=1; d<=5; d++) {
