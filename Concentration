      html += `
        <div style="padding:10px;background:rgba(15,23,42,0.5);border-radius:10px;">
          <div style="font-size:11px;color:#94a3b8;">Level ${d} · ${MEMORY_CFG[d].label}</div>
          <div style="font-size:13px;margin-top:4px;">Best: <b style="color:#a5b4fc;">${s.bl}</b> digits</div>
          <div style="font-size:13px;">Plays: <b>${s.plays}</b></div>
        </div>`;
    }
    html += '</div>';
    c.innerHTML = html;
  }
}

function renderLeaderboard(type) {
  const c = document.getElementById('leaderboard-content');
  if (type === 'schulte') {
    // rank by best classic time at highest attempted level (lower = better). Use level 3 as "standard".
    const rows = state.profiles.map(p => {
      // pick best time from any level (fastest overall)
      let bt = null, level = null;
      for (let d=5; d>=1; d--) {
        if (p.schulte.stats[d].bt != null) {
          if (bt == null || p.schulte.stats[d].bt < bt) { bt = p.schulte.stats[d].bt; level = d; }
        }
      }
      return { p, bt, level };
    }).filter(r => r.bt != null).sort((a,b) => a.bt - b.bt);
    if (rows.length === 0) { c.innerHTML = '<div class="empty">No Schulte runs yet.</div>'; return; }
    c.innerHTML = rows.slice(0,10).map((r,i) => {
      const ring = RING_COLORS[r.p.ringIdx % RING_COLORS.length];
      const cls = i===0?'gold':i===1?'silver':i===2?'bronze':'';
      return `<div class="lb-entry">
        <div class="lb-rank ${cls}">${i+1}</div>
        <div class="avatar" style="width:32px;height:32px;font-size:16px;margin:0;--ring-a:${ring[0]};--ring-b:${ring[1]}">${r.p.avatar}</div>
        <div class="lb-name">${escapeHtml(r.p.name)} <span style="color:#94a3b8;font-size:11px;font-weight:500;">L${r.level}</span></div>
        <div class="lb-score">${r.bt.toFixed(1)}s</div>
      </div>`;
    }).join('');
  } else {
    const rows = state.profiles.map(p => ({ p, bl: p.memory.bestLength, bs: p.memory.bestScore }))
      .filter(r => r.bl > 0).sort((a,b) => b.bl - a.bl || b.bs - a.bs);
    if (rows.length === 0) { c.innerHTML = '<div class="empty">No Memory runs yet.</div>'; return; }
    c.innerHTML = rows.slice(0,10).map((r,i) => {
      const ring = RING_COLORS[r.p.ringIdx % RING_COLORS.length];
      const cls = i===0?'gold':i===1?'silver':i===2?'bronze':'';
      return `<div class="lb-entry">
        <div class="lb-rank ${cls}">${i+1}</div>
        <div class="avatar" style="width:32px;height:32px;font-size:16px;margin:0;--ring-a:${ring[0]};--ring-b:${ring[1]}">${r.p.avatar}</div>
        <div class="lb-name">${escapeHtml(r.p.name)}</div>
        <div class="lb-score">${r.bl} digits</div>
      </div>`;
    }).join('');
  }
}

/* ==================== SCHULTE CONFIG ==================== */
// Age-graded difficulty (grid size dominates): 5-8 → 3×3, 8-12 → 4×4, 12-15 → 5×5,
// 15-18 → 6×6, 18+ → 7×7. Harder levels also use a denser visual style.
const SCHULTE_CFG = {
  1: { size: 3, label: '5–8 yrs', desc: '3×3 grid · numbers 1–9. Gentle introduction for young children.' },
  2: { size: 4, label: '8–12 yrs', desc: '4×4 grid · numbers 1–16. Standard beginner training.' },
  3: { size: 5, label: '12–15 yrs', desc: '5×5 grid · numbers 1–25. The classic Schulte table.' },
  4: { size: 6, label: '15–18 yrs', desc: '6×6 grid · numbers 1–36. Challenging attention span.' },
  5: { size: 7, label: '18+ yrs', desc: '7×7 grid · numbers 1–49. Advanced peripheral focus.' }
};
let schulteDiff = 3, schulteMode = 'classic';
let schulteGame = null;

function renderSchulteSetup() {
  const row = document.getElementById('schulte-diff-row');
  row.innerHTML = '';
  for (let d=1; d<=5; d++) {
    const el = document.createElement('div');
    el.className = 'diff-chip' + (d === schulteDiff ? ' active' : '');
    el.innerHTML = `<span class="num">L${d}</span>${SCHULTE_CFG[d].label}`;
    el.onclick = () => { schulteDiff = d; renderSchulteSetup(); };
    row.appendChild(el);
  }
  document.getElementById('schulte-diff-desc').textContent = SCHULTE_CFG[schulteDiff].desc;
  document.getElementById('smode-classic').classList.toggle('active', schulteMode === 'classic');
  document.getElementById('smode-timed').classList.toggle('active', schulteMode === 'timed');
}
function setSchulteMode(m) { schulteMode = m; renderSchulteSetup(); }

/* ==================== SCHULTE PLAY ==================== */
function startSchulte() {
  schulteGame = {
    size: SCHULTE_CFG[schulteDiff].size,
    target: 1, errors: 0, startTime: Date.now(),
    mode: schulteMode, completed: 0,
    timerEnd: schulteMode === 'timed' ? Date.now() + 120000 : null,
    raf: null
  };
  buildSchulteGrid();
  goto('schulte-play');
  document.getElementById('s-extra2-label').textContent = 'Grid';
  document.getElementById('s-extra2').textContent = `${schulteGame.size}×${schulteGame.size}`;
  if (schulteMode === 'timed') {
    document.getElementById('s-extra-label').textContent = 'Grids';
    document.getElementById('s-extra').textContent = '0';
    document.getElementById('s-timer-bar').style.display = 'block';
  } else {
    document.getElementById('s-extra-label').textContent = 'Errors';
    document.getElementById('s-extra').textContent = '0';
    document.getElementById('s-timer-bar').style.display = 'none';
  }
  tickSchulte();
}

function buildSchulteGrid() {
  const grid = document.getElementById('schulte-grid');
  const n = schulteGame.size;
  grid.style.gridTemplateColumns = `repeat(${n}, 1fr)`;
  // Font size scales with grid
  const fontSize = n === 3 ? 42 : n === 4 ? 36 : n === 5 ? 28 : n === 6 ? 22 : 18;
  const nums = []; for (let i=1; i<=n*n; i++) nums.push(i);
  shuffle(nums);
  grid.innerHTML = '';
  nums.forEach(num => {
    const cell = document.createElement('div');
    cell.className = 'schulte-cell';
    cell.textContent = num;
    cell.style.fontSize = fontSize + 'px';
    cell.dataset.num = num;
    cell.onclick = () => tapSchulteCell(cell, num);
    grid.appendChild(cell);
  });
  schulteGame.target = 1;
  document.getElementById('s-target').textContent = '1';
}

function tapSchulteCell(cell, num) {
  if (!schulteGame) return;
  if (num === schulteGame.target) {
    cell.classList.add('correct');
    cell.onclick = null;
    schulteGame.target++;
    document.getElementById('s-target').textContent = schulteGame.target;
    if (schulteGame.target > schulteGame.size * schulteGame.size) {
      onSchulteComplete();
    }
  } else {
    cell.classList.add('wrong');
    setTimeout(() => cell.classList.remove('wrong'), 300);
    if (schulteGame.mode === 'classic') {
      schulteGame.errors++;
      document.getElementById('s-extra').textContent = schulteGame.errors;
    }
  }
}

function onSchulteComplete() {
  if (schulteGame.mode === 'classic') {
    const elapsed = (Date.now() - schulteGame.startTime) / 1000;
    const p = currentProfile();
    const st = p.schulte.stats[schulteDiff];
    st.plays++;
    const isBest = st.bt == null || elapsed < st.bt;
    if (isBest) st.bt = elapsed;
    saveState();
    cancelAnimationFrame(schulteGame.raf);
    showOverlay({
      emoji: isBest ? '🏆' : '🎯',
      title: isBest ? 'New Best Time!' : 'Grid Complete!',
      sub: `Level ${schulteDiff} · ${schulteGame.size}×${schulteGame.size}`,
      stats: [
        { label: 'Time', value: elapsed.toFixed(1) + 's' },
        { label: 'Errors', value: schulteGame.errors },
        { label: 'Best', value: st.bt.toFixed(1) + 's' },
        { label: 'Plays', value: st.plays }
      ],
      again: () => { closeOverlay(); startSchulte(); }
    });
    schulteGame = null;
  } else {
    // Sprint: move to next grid, increment count
    schulteGame.completed++;
    document.getElementById('s-extra').textContent = schulteGame.completed;
    buildSchulteGrid();
  }
}

function tickSchulte() {
  if (!schulteGame) return;
  const now = Date.now();
  if (schulteGame.mode === 'classic') {
    const elapsed = (now - schulteGame.startTime) / 1000;
    document.getElementById('s-time').textContent = elapsed.toFixed(1);
  } else {
    const remain = Math.max(0, schulteGame.timerEnd - now);
    const secs = remain / 1000;
    document.getElementById('s-time').textContent = secs.toFixed(1);
    document.getElementById('s-timer-fill').style.width = (remain / 120000 * 100) + '%';
    if (remain <= 0) {
      const p = currentProfile();
      const st = p.schulte.stats[schulteDiff];
      st.plays++;
      const isBest = schulteGame.completed > st.btc;
      if (isBest) st.btc = schulteGame.completed;
      saveState();
      const total = schulteGame.completed;
      schulteGame = null;
      showOverlay({
        emoji: isBest ? '🏆' : '🔥',
        title: isBest ? 'New Sprint Record!' : 'Time\'s Up!',
        sub: `Level ${schulteDiff} · 2-Minute Sprint`,
        stats: [
          { label: 'Grids', value: total },
          { label: 'Best', value: st.btc },
          { label: 'Level', value: schulteDiff },
          { label: 'Plays', value: st.plays }
        ],
        again: () => { closeOverlay(); startSchulte(); }
      });
      return;
    }
  }
  schulteGame.raf = requestAnimationFrame(tickSchulte);
}

function quitSchulte() {
  if (schulteGame) cancelAnimationFrame(schulteGame.raf);
  schulteGame = null;
  goto('home');
}

/* ==================== MEMORY CONFIG ==================== */
// Starting length + show-time per digit graded by age.
const MEMORY_CFG = {
  1: { label: '5–8 yrs', start: 3, showMs: 1000, desc: 'Starts at 3 digits · 1 second per digit. Kind to young minds.' },
  2: { label: '8–12 yrs', start: 4, showMs: 850, desc: 'Starts at 4 digits · 0.85s per digit. Standard practice.' },
  3: { label: '12–15 yrs', start: 5, showMs: 700, desc: 'Starts at 5 digits · 0.7s per digit.' },
  4: { label: '15–18 yrs', start: 6, showMs: 600, desc: 'Starts at 6 digits · 0.6s per digit.' },
  5: { label: '18+ yrs', start: 7, showMs: 500, desc: 'Starts at 7 digits · 0.5s per digit. Challenging.' }
};
let memoryDiff = 3, memoryMode = 'classic';
let memoryGame = null;

function renderMemorySetup() {
  const row = document.getElementById('memory-diff-row');
  row.innerHTML = '';
  for (let d=1; d<=5; d++) {
    const el = document.createElement('div');
    el.className = 'diff-chip' + (d === memoryDiff ? ' active' : '');
    el.innerHTML = `<span class="num">L${d}</span>${MEMORY_CFG[d].label}`;
    el.onclick = () => { memoryDiff = d; renderMemorySetup(); };
    row.appendChild(el);
  }
  document.getElementById('memory-diff-desc').textContent = MEMORY_CFG[memoryDiff].desc;
  document.getElementById('mmode-classic').classList.toggle('active', memoryMode === 'classic');
  document.getElementById('mmode-timed').classList.toggle('active', memoryMode === 'timed');
}
function setMemoryMode(m) { memoryMode = m; renderMemorySetup(); }

/* ==================== MEMORY PLAY ==================== */
function startMemory() {
  const cfg = MEMORY_CFG[memoryDiff];
  memoryGame = {
    round: 1, length: cfg.start, showMs: cfg.showMs,
    sequence: '', input: '', score: 0, best: 0,
    mode: memoryMode, phase: 'show',
    timerEnd: memoryMode === 'timed' ? Date.now() + 120000 : null,
    raf: null
  };
  goto('memory-play');
  document.getElementById('m-extra-label').textContent = memoryMode === 'timed' ? 'Time' : 'Best';
  if (memoryMode === 'timed') {
    document.getElementById('m-timer-bar').style.display = 'block';
    tickMemoryTimer();
  } else {
    document.getElementById('m-timer-bar').style.display = 'none';
  }
  nextRound();
}

function nextRound() {
  if (!memoryGame) return;
  memoryGame.input = '';
  memoryGame.sequence = '';
  for (let i=0; i<memoryGame.length; i++) memoryGame.sequence += Math.floor(Math.random()*10);
  document.getElementById('m-round').textContent = memoryGame.round;
  document.getElementById('m-length').textContent = memoryGame.length;
  document.getElementById('m-score').textContent = memoryGame.score;
  document.getElementById('m-extra').textContent = memoryMode === 'timed'
    ? Math.max(0, Math.ceil((memoryGame.timerEnd - Date.now())/1000))
    : memoryGame.best;
  document.getElementById('memory-keypad').style.display = 'none';
  showMemorySequence();
}

function showMemorySequence() {
  if (!memoryGame) return;
  memoryGame.phase = 'show';
  const disp = document.getElementById('memory-display');
  disp.className = 'memory-display';
  disp.innerHTML = '<div class="hint">Get ready…</div>';
  setTimeout(() => {
    if (!memoryGame) return;
    let i = 0;
    const showNext = () => {
      if (!memoryGame) return;
      if (i >= memoryGame.sequence.length) {
        disp.className = 'memory-display';
        disp.innerHTML = '<div class="hint">Type what you saw</div>';
        setTimeout(() => {
          if (!memoryGame) return;
          memoryGame.phase = 'input';
          disp.className = 'memory-display input';
          disp.innerHTML = '<span id="mem-typed">_</span>';
          document.getElementById('memory-keypad').style.display = 'block';
        }, 500);
        return;
      }
      disp.className = 'memory-display sequence';
      disp.innerHTML = memoryGame.sequence[i];
      i++;
      setTimeout(() => {
        if (!memoryGame) return;
        disp.innerHTML = '';
        setTimeout(showNext, 150);
      }, memoryGame.showMs);
    };
    showNext();
  }, 700);
}

function mKey(d) {
  if (!memoryGame || memoryGame.phase !== 'input') return;
  if (memoryGame.input.length >= memoryGame.sequence.length) return;
  memoryGame.input += d;
  updateMemoryTyped();
  if (memoryGame.input.length === memoryGame.sequence.length) {
    setTimeout(mSubmit, 150);
  }
}
function mBack() {
  if (!memoryGame || memoryGame.phase !== 'input') return;
  memoryGame.input = memoryGame.input.slice(0, -1);
  updateMemoryTyped();
}
function updateMemoryTyped() {
  const el = document.getElementById('mem-typed');
  if (el) el.textContent = memoryGame.input || '_';
}
function mSubmit() {
  if (!memoryGame || memoryGame.phase !== 'input') return;
  if (memoryGame.input.length === 0) return;
  const correct = memoryGame.input === memoryGame.sequence;
  memoryGame.phase = 'done';
  document.getElementById('memory-keypad').style.display = 'none';
  const disp = document.getElementById('memory-display');
  if (correct) {
    disp.className = 'memory-display';
    disp.innerHTML = `<div style="color:#10b981;">✓ ${memoryGame.sequence}</div>`;
    memoryGame.score += memoryGame.length * 10;
    if (memoryGame.length > memoryGame.best) memoryGame.best = memoryGame.length;
    // save best globally
    const p = currentProfile();
    if (memoryGame.length > p.memory.stats[memoryDiff].bl) p.memory.stats[memoryDiff].bl = memoryGame.length;
    if (memoryGame.length > p.memory.bestLength) p.memory.bestLength = memoryGame.length;
    if (memoryGame.score > p.memory.bestScore) p.memory.bestScore = memoryGame.score;
    saveState();
    setTimeout(() => {
      if (!memoryGame) return;
      memoryGame.round++;
      memoryGame.length++;
      // In timed mode, check remaining time before starting next round
      if (memoryGame.mode === 'timed' && memoryGame.timerEnd - Date.now() <= 0) {
        endMemory(true);
      } else {
        nextRound();
      }
    }, 1000);
  } else {
    disp.className = 'memory-display';
    disp.innerHTML = `<div style="color:#ef4444;font-size:28px;">Answer: ${memoryGame.sequence}</div><div class="hint" style="margin-top:8px;">You typed: ${memoryGame.input}</div>`;
    // classic: game over. timed: count as miss but keep going with same length (no grow).
    const p = currentProfile();
    p.memory.stats[memoryDiff].plays++;
    saveState();
    if (memoryGame.mode === 'classic') {
      setTimeout(() => endMemory(false), 1500);
    } else {
      setTimeout(() => {
        if (!memoryGame) return;
        memoryGame.round++;
        // slightly back off in timed mode
        if (memoryGame.length > MEMORY_CFG[memoryDiff].start) memoryGame.length--;
        if (memoryGame.timerEnd - Date.now() <= 0) endMemory(true);
        else nextRound();
      }, 1800);
    }
  }
}

function tickMemoryTimer() {
  if (!memoryGame || memoryGame.mode !== 'timed') return;
  const remain = Math.max(0, memoryGame.timerEnd - Date.now());
  document.getElementById('m-extra').textContent = Math.ceil(remain / 1000);
  document.getElementById('m-timer-fill').style.width = (remain / 120000 * 100) + '%';
  if (remain <= 0 && memoryGame.phase !== 'done') {
    endMemory(true);
    return;
  }
  memoryGame.raf = requestAnimationFrame(tickMemoryTimer);
}

function endMemory(isTimed) {
  if (!memoryGame) return;
  if (memoryGame.raf) cancelAnimationFrame(memoryGame.raf);
  const p = currentProfile();
  const st = p.memory.stats[memoryDiff];
  st.plays = (st.plays || 0);
  if (memoryGame.best > st.bl) st.bl = memoryGame.best;
  if (memoryGame.best > p.memory.bestLength) p.memory.bestLength = memoryGame.best;
  if (memoryGame.score > p.memory.bestScore) p.memory.bestScore = memoryGame.score;
  saveState();
  const best = memoryGame.best, score = memoryGame.score, round = memoryGame.round;
  const wasNewBest = memoryGame.best === p.memory.stats[memoryDiff].bl && memoryGame.best > 0;
  memoryGame = null;
  showOverlay({
    emoji: wasNewBest ? '🏆' : (isTimed ? '🔥' : '🧠'),
    title: wasNewBest ? 'New Memory Record!' : (isTimed ? 'Time\'s Up!' : 'Round Over'),
    sub: `Level ${memoryDiff} · ${isTimed ? '2-Minute Sprint' : 'Classic'}`,
    stats: [
      { label: 'Best Length', value: best },
      { label: 'Score', value: score },
      { label: 'Rounds', value: round },
      { label: 'All-Time', value: p.memory.bestLength }
    ],
    again: () => { closeOverlay(); startMemory(); }
  });
}

function quitMemory() {
  if (memoryGame && memoryGame.raf) cancelAnimationFrame(memoryGame.raf);
  memoryGame = null;
  goto('home');
}

/* ==================== OVERLAY ==================== */
function showOverlay({ emoji, title, sub, stats, again }) {
  document.getElementById('ov-emoji').textContent = emoji;
  document.getElementById('ov-title').textContent = title;
  document.getElementById('ov-sub').textContent = sub || '';
  const sc = document.getElementById('ov-stats');
  sc.innerHTML = stats.map(s => `<div class="overlay-stat"><div class="stat-label">${s.label}</div><div class="stat-value">${s.value}</div></div>`).join('');
  document.getElementById('ov-again').onclick = again;
  document.getElementById('overlay').classList.add('active');
}
function closeOverlay() { document.getElementById('overlay').classList.remove('active'); }

/* ==================== UTILS ==================== */
function shuffle(a) {
  for (let i=a.length-1; i>0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}
function escapeHtml(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

/* ==================== INIT ==================== */
renderHome();

// Prevent pull-to-refresh interfering during play
document.body.addEventListener('touchmove', e => {
  if (document.querySelector('#screen-schulte-play.active') || document.querySelector('#screen-memory-play.active')) {
    if (e.touches.length === 1) e.preventDefault();
  }
}, { passive: false });
</script>

